<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <ImageView
            android:id="@+id/imageViewLogo"
            android:layout_width="match_parent"
            android:layout_height="96dp"
            android:layout_marginTop="0dp"
            android:scaleType="fitCenter"
            android:src="@drawable/logo" />

        <TextView
            android:id="@+id/text_app_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center"
            android:text="Bladder GUI"
            android:textColor="#102A43"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_app_version"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:text="Version V1.1"
            android:textColor="#526A7A"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/calibration_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel_modern"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Calibration"
                android:textColor="#102A43"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/text_initial_resistance_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Initial Resistance"
                android:textColor="#334E68"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edit_initial_resistance"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_input_modern"
                android:inputType="numberDecimal"
                android:singleLine="true"
                android:text="3.75"
                android:textColor="#102A43"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/text_slope_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Slope"
                android:textColor="#334E68"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edit_slope"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_input_modern"
                android:inputType="numberDecimal"
                android:singleLine="true"
                android:text="263"
                android:textColor="#102A43"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/text_calibration_constant_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Calibration Constant"
                android:textColor="#334E68"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/edit_calibration_constant"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_input_modern"
                android:inputType="numberDecimal|numberSigned"
                android:singleLine="true"
                android:text="0.0"
                android:textColor="#102A43"
                android:textSize="18sp" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="8dp" />

        <ImageButton
            android:id="@+id/button_bladder_volume"
            android:layout_width="142dp"
            android:layout_height="142dp"
            android:layout_gravity="center_horizontal"
            android:background="@android:color/transparent"
            android:scaleType="fitCenter"
            android:src="@drawable/bladder" />

        <TextView
            android:id="@+id/text_bladder_volume_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Start Bladder Volume Monitor"
            android:textColor="#006D77"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_developed_by"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Developed by: Shahriar Shalileh"
            android:textColor="#526A7A"
            android:textSize="13sp"
            android:textStyle="italic" />
    </LinearLayout>
</ScrollView>
